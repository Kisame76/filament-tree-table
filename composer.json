{
  "name": "kisame76/filament-tree-table",
  "description": "Expandable parent/child tree rows for Filament v4 & v5 tables — inline sub-rows, search/filter aware, expand & collapse all.",
  "keywords": [
    "filament",
    "filamentphp",
    "laravel",
    "table",
    "tree",
    "nested",
    "expandable",
    "hierarchy"
  ],
  "homepage": "https://github.com/Kisame76/filament-tree-table",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/Kisame76/filament-tree-table/issues",
    "source": "https://github.com/Kisame76/filament-tree-table"
  },
  "authors": [
    {
      "name": "Kiyan Doguc",
      "email": "k.doguc@kisame-labs.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "filament/actions": "^4.0||^5.0",
    "filament/support": "^4.0||^5.0",
    "filament/tables": "^4.0||^5.0",
    "illuminate/contracts": "^11.0||^12.0||^13.0",
    "illuminate/database": "^11.0||^12.0||^13.0",
    "illuminate/support": "^11.0||^12.0||^13.0",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "filament/filament": "^4.0||^5.0",
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^9.0||^10.0||^11.0",
    "pestphp/pest": "^3.0||^4.0",
    "pestphp/pest-plugin-laravel": "^3.0||^4.0",
    "pestphp/pest-plugin-livewire": "^3.0||^4.0"
  },
  "autoload": {
    "psr-4": {
      "Kisame76\\FilamentTreeTable\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kisame76\\FilamentTreeTable\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "pint": "vendor/bin/pint",
    "test": "vendor/bin/pest"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Kisame76\\FilamentTreeTable\\FilamentTreeTableServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
